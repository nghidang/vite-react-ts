# Template cho .env.local — cấu hình máy CÁ NHÂN, KHÔNG commit (đã bị .gitignore qua "*.local").
# Copy file này thành .env.local rồi chỉnh theo backend local của bạn:
#   cp .env.example .env.local
# `yarn dev` chạy ở mode "local" => Vite nạp .env + .env.local.
# Không tạo .env.local cũng được: code đã có default (xem src/configs/env.config.ts).

VITE_APP_ENV=local
VITE_API_BASE_URL=http://localhost:3000/api
VITE_ENABLE_DEVTOOLS=true
